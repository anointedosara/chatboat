# --- Twilio Verify (real SMS OTP) ---
# When these three are set, the app sends + verifies OTPs via Twilio Verify.
# Leave them unset for local "dev mode" (the code is shown on the OTP screen).
#
# Where to find them:
#   ACCOUNT SID + AUTH TOKEN: Twilio Console home (https://console.twilio.com)
#   VERIFY SERVICE SID:       Verify → Services → create a service → copy the SID (starts with "VA")
#
# On Vercel: add these under Project → Settings → Environment Variables, then redeploy.

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# --- Upstash Redis (chat messages + conversations) ---
# Needed for messaging to work on Vercel (the in-memory store does not persist
# across serverless instances). Easiest setup: Vercel → Storage → Upstash Redis
# (the integration adds these automatically). Leave unset for local in-memory dev.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Vercel Blob (chat attachments + voice notes) ---
# Needed so uploaded files persist on Vercel. Set up via Vercel → Storage → Blob;
# the integration adds this automatically. Leave unset for local in-memory dev.
BLOB_READ_WRITE_TOKEN=
